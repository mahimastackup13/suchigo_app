# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Flutter web — bootstrap script is generated by flutter build web
web/flutter_bootstrap.js

# Android signing secrets — NEVER commit these
android/key.properties
*.jks
*.p12

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# FVM Version Cache — the SDK symlinks are machine-local, .fvmrc IS committed.
# See: https://fvm.app/docs/guides/gitignore
.fvm/versions/
.fvm/flutter_sdk
# Keep .fvmrc committed (pin file) — do NOT ignore it.